# Entorno y secretos
.venv/
.env
.env.*
!.env.example

# Cachés de Python y herramientas
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# Notebooks (salidas temporales)
.ipynb_checkpoints/
*.executed.ipynb
*.nbconvert.ipynb

# Sistema operativo / IDE
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# Archivos comprimidos (entregables/empaquetados; no se versionan)
*.zip

# Documentación interna/operativa — decisión del autor: NO versionar (se mantiene en local).
# CLAUDE.md y ARCHITECTURE.md son guías operativas; docs/ es documentación técnica detallada.
# Se conservan en el disco de trabajo pero no se publican en GitHub.
.claude/
CLAUDE.md
ARCHITECTURE.md
PROGRESO.md
sessions/
docs/
PLAN.md

# Datos reales: no versionar contenido crudo ni artefactos generados; conservar los .gitkeep
data/raw/boe/*
!data/raw/boe/.gitkeep
data/processed/documents/*
!data/processed/documents/.gitkeep
data/processed/histories/*
!data/processed/histories/.gitkeep
data/processed/parents/*
!data/processed/parents/.gitkeep
data/processed/chunks/*
!data/processed/chunks/.gitkeep

# Reports de experimentos (retrieval/FAISS/generación/auditoría): SÍ se versionan — son evidencia
# reproducible para la memoria y permiten compartir resultados servidor↔local con un push/pull.
# (Antes estaban ignorados; conviene hacer `git add` selectivo de los runs que se quieran conservar.)

# Índices locales (se generan en runtime)
data/indexes/
