# Entorno y secretos
.venv/
.env
.env.*
!.env.example

# Cachés de Python y herramientas
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# Notebooks (salidas temporales)
.ipynb_checkpoints/
*.executed.ipynb
*.nbconvert.ipynb

# Sistema operativo / IDE
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# Archivos comprimidos (entregables/empaquetados; no se versionan)
*.zip

# Guías operativas internas y estado de trabajo: no se versionan, se mantienen en local.
.claude/
CLAUDE.md
ARCHITECTURE.md
PROGRESO.md
sessions/
PLAN.md

# Documentación: por defecto no se versiona (notas internas de trabajo); se publica solo el
# subconjunto curado de abajo (diseño, evaluación, análisis del parser, fuentes y licencias).
# El resto de docs/ (runbooks del servidor, protocolos de anotación, hoja de ruta, archivo) es local.
docs/*
!docs/decisiones_de_diseno.md
!docs/evaluacion_gold_y_metricas.md
!docs/fase2_dense_baseline.md
!docs/fuentes_y_licencias.md
!docs/analisis_errores_generacion.md
!docs/analisis/
!docs/analisis/*

# Datos reales: no versionar contenido crudo ni artefactos generados; conservar los .gitkeep
data/raw/boe/*
!data/raw/boe/.gitkeep
# Excepción: el raw de las 10 normas del MVP SÍ se versiona (reproducibilidad de la campaña de
# embeddings: el servidor indexa los MISMOS bytes que describen los manifests re-baselinados). El
# resto del raw (normas de ampliación) sigue ignorado. Ver docs/analisis/06 y 07.
!data/raw/boe/BOE-A-1985-5392/
!data/raw/boe/BOE-A-2003-20977/
!data/raw/boe/BOE-A-2004-4214/
!data/raw/boe/BOE-A-2006-13371/
!data/raw/boe/BOE-A-2013-12887/
!data/raw/boe/BOE-A-2015-10565/
!data/raw/boe/BOE-A-2015-10566/
!data/raw/boe/BOE-A-2017-12902/
!data/raw/boe/BOE-A-2018-16673/
!data/raw/boe/BOE-A-2021-5032/
data/processed/documents/*
!data/processed/documents/.gitkeep
data/processed/histories/*
!data/processed/histories/.gitkeep
data/processed/parents/*
!data/processed/parents/.gitkeep
data/processed/chunks/*
!data/processed/chunks/.gitkeep
data/processed/reports/*
!data/processed/reports/.gitkeep

# Índices locales (se generan en runtime)
data/indexes/

# Material de trabajo del pooling de evaluación (derivado de bundles no versionados; regenerable)
data/evaluation/dense_retrieval_v1/_candidates/
