BOE_API_BASE=https://www.boe.es/datosabiertos/api
LOG_LEVEL=INFO

# Ollama (LLM local de generación — Fase 3). Default loopback; no se expone a la red.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0
OLLAMA_SEED=42
OLLAMA_THINK=false
# Salvaguarda: solo se permite una URL de Ollama no-loopback con opt-in explícito.
OLLAMA_ALLOW_REMOTE=false

# Generación fundamentada (Fase 3). El bundle NO es un default global: se indica aquí o por --bundle.
#   GENERATION_DENSE_BUNDLE=data/indexes/dense/e5-large-instruct__j1__bc11142bdcc5
GENERATION_DENSE_BUNDLE=
GENERATION_QUERY_PROFILE_ID=I2_CITIZEN_LEGISLATION
GENERATION_TOP_K=5
GENERATION_MAX_EVIDENCES=3
GENERATION_CONTEXT_STRATEGY=P_EXPAND_BOUNDED
GENERATION_CONTEXT_BUDGET_CHARS=4000
GENERATION_MAX_TOTAL_CONTEXT_CHARS=8000

# Juez LLM de evaluación (L3 fidelidad / L5 corrección). DEBE ser un modelo distinto del generador
# (y a ser posible más fuerte) para evitar el sesgo de auto-preferencia. NO tiene default global:
# se indica aquí (JUDGE_MODEL) o por --judge-model en scripts/run_generation_eval.py.
JUDGE_BASE_URL=http://127.0.0.1:11434
JUDGE_MODEL=
JUDGE_TIMEOUT_SECONDS=900
JUDGE_NUM_CTX=8192
JUDGE_NUM_PREDICT=2048
JUDGE_TEMPERATURE=0
JUDGE_SEED=42
JUDGE_KEEP_ALIVE=5m

# Índice denso (Fase 2). El modelo de embeddings NO es un default global: se elige por
# --model en los scripts (p. ej. scripts/generate_dense_index.py --model bge-m3).
DENSE_INDEX_ROOT=data/indexes/dense
DEFAULT_CPU_THREADS=8
MAX_CPU_THREADS=16

# Autenticación opcional de Hugging Face. SOLO se exporta en el entorno cuando un modelo
# requiere autenticación; nunca se versiona ni se pega un token real aquí.
#   export HF_TOKEN="<token-read-only-externo>"   # bash
#   $env:HF_TOKEN = "<token-read-only-externo>"   # PowerShell
# No definas HF_TOKEN en este fichero.
