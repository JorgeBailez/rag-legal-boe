BOE_API_BASE=https://www.boe.es/datosabiertos/api
LOG_LEVEL=INFO

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Índice denso (Fase 2). El modelo de embeddings NO es un default global: se elige por
# --model en los scripts (p. ej. scripts/generate_dense_index.py --model bge-m3).
DENSE_INDEX_ROOT=data/indexes/dense
DEFAULT_CPU_THREADS=8
MAX_CPU_THREADS=16

# Autenticación opcional de Hugging Face. SOLO se exporta en el entorno cuando un modelo
# requiere autenticación; nunca se versiona ni se pega un token real aquí.
#   export HF_TOKEN="<token-read-only-externo>"   # bash
#   $env:HF_TOKEN = "<token-read-only-externo>"   # PowerShell
# No definas HF_TOKEN en este fichero.
