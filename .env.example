BOE_API_BASE=https://www.boe.es/datosabiertos/api
LOG_LEVEL=INFO

# Ollama local para generación. Por defecto solo se permite loopback.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=1536
OLLAMA_TEMPERATURE=0
OLLAMA_SEED=42
OLLAMA_THINK=false
# Salvaguarda: solo se permite una URL de Ollama no-loopback con opt-in explícito.
OLLAMA_ALLOW_REMOTE=false

# Generación fundamentada. El bundle se indica aquí o por --bundle.
#   GENERATION_DENSE_BUNDLE=data/indexes/dense/e5-large-instruct__j1__bc11142bdcc5
GENERATION_DENSE_BUNDLE=
GENERATION_QUERY_PROFILE_ID=I1_LEGAL
GENERATION_TOP_K=3
GENERATION_MAX_EVIDENCES=3
GENERATION_CONTEXT_STRATEGY=P_EXPAND_BOUNDED
GENERATION_CONTEXT_BUDGET_CHARS=4000
GENERATION_MAX_TOTAL_CONTEXT_CHARS=16000

# Juez LLM de evaluación. Debe configurarse explícitamente para los scripts que lo usan.
JUDGE_BASE_URL=http://127.0.0.1:11434
JUDGE_MODEL=
JUDGE_TIMEOUT_SECONDS=900
JUDGE_NUM_CTX=8192
JUDGE_NUM_PREDICT=2048
JUDGE_TEMPERATURE=0
JUDGE_SEED=42
JUDGE_KEEP_ALIVE=5m

# Índice denso. El modelo de embeddings se elige con --model.
DENSE_INDEX_ROOT=data/indexes/dense
DEFAULT_CPU_THREADS=8
MAX_CPU_THREADS=16

# Autenticación opcional de Hugging Face. Nunca pegues un token real en este fichero.
#   export HF_TOKEN="<token-read-only-externo>"   # bash
#   $env:HF_TOKEN = "<token-read-only-externo>"   # PowerShell
# No definas HF_TOKEN en este fichero.
